---
/**
 * Footer — usa-footer
 * https://designsystem.digital.gov/components/footer/
 *
 * Three variants: slim, medium, big.
 * The USAIdentifier (required for gov sites) is separate and rendered
 * after this footer in BaseLayout.
 */

import type { Locale } from '../../i18n/utils';
import { useTranslations, withBase } from '../../i18n/utils';
import { siteConfig } from '../../config/site';

interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  heading: string;
  links: FooterLink[];
}

interface Props {
  locale?: Locale;
  /** 'slim' | 'medium' | 'big' */
  variant?: 'slim' | 'medium' | 'big';
  columns?: FooterColumn[];
  class?: string;
}

const {
  locale = 'en',
  variant = 'medium',
  columns,
  class: className,
} = Astro.props;

const t = useTranslations(locale);

const defaultColumns: FooterColumn[] =
  locale === 'es'
    ? [
        {
          heading: 'Servicios',
          links: [
            { label: 'SNAP', href: '/es/services/snap/' },
            { label: 'Medicaid', href: '/es/services/medicaid/' },
            { label: 'WIC', href: '/es/services/wic/' },
            { label: 'Cuidado infantil', href: '/es/services/childcare/' },
          ],
        },
        {
          heading: 'Ayuda',
          links: [
            { label: 'Centro de ayuda', href: '/es/help/' },
            { label: 'Contáctenos', href: '/es/contact/' },
            { label: 'Accesibilidad', href: '/accessibility/' },
            { label: 'Privacidad', href: '/privacy/' },
          ],
        },
      ]
    : [
        {
          heading: 'Services',
          links: [
            { label: 'SNAP Benefits', href: '/services/snap/' },
            { label: 'Medicaid', href: '/services/medicaid/' },
            { label: 'WIC', href: '/services/wic/' },
            { label: 'Child Care', href: '/services/childcare/' },
          ],
        },
        {
          heading: 'Help',
          links: [
            { label: 'Help center', href: '/help/' },
            { label: 'Contact us', href: '/contact/' },
            { label: 'Accessibility', href: '/accessibility/' },
            { label: 'Privacy policy', href: '/privacy/' },
          ],
        },
      ];

const resolvedColumns = columns ?? defaultColumns;
---

<footer class:list={['usa-footer', `usa-footer--${variant}`, className]}>
  {variant !== 'slim' && (
    <div class="grid-container usa-footer__return-to-top">
      <a href="#">Return to top</a>
    </div>
  )}

  {resolvedColumns.length > 0 && (
    <div class="usa-footer__primary-section">
      <div class="grid-container">
        <div class="grid-row grid-gap">
          {resolvedColumns.map((col) => (
            <div class="mobile-lg:grid-col-6 desktop:grid-col-3">
              <section class="usa-footer__primary-content usa-footer__primary-content--collapsible">
                <h2 class="usa-footer__primary-link">{col.heading}</h2>
                <ul class="usa-list usa-list--unstyled">
                  {col.links.map((link) => (
                    <li class="usa-footer__secondary-link">
                      <a href={withBase(link.href)}>{link.label}</a>
                    </li>
                  ))}
                </ul>
              </section>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

  <div class="usa-footer__secondary-section">
    <div class="grid-container">
      <div class="grid-row grid-gap">
        <div class="usa-footer__logo grid-row mobile-lg:grid-col-6 mobile-lg:grid-gap-2">
          <div class="mobile-lg:grid-col-auto">
            <p class="usa-footer__logo-heading">{siteConfig.name}</p>
          </div>
        </div>
        <div class="usa-footer__contact-links mobile-lg:grid-col-6">
          <h2 class="usa-footer__contact-heading">
            {t('footer.contactUs')}
          </h2>
          <address class="usa-footer__address">
            <div class="usa-footer__contact-info grid-row grid-gap">
              <div class="grid-col-auto">
                <a href={`tel:${t('footer.phone').replace(/[^0-9]/g, '')}`}>
                  {t('footer.phone')}
                </a>
              </div>
              <div class="grid-col-auto">
                <a href={`mailto:${t('footer.email')}`}>
                  {t('footer.email')}
                </a>
              </div>
            </div>
          </address>
        </div>
      </div>
    </div>
  </div>
</footer>
