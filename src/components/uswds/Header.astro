---
import type { Locale } from '../../i18n/utils';
import { useTranslations, localizeUrl } from '../../i18n/utils';
import { siteConfig } from '../../config/site';

interface NavLink {
  label: string;
  href: string;
  current?: boolean;
}

interface Props {
  locale?: Locale;
  currentPath?: string;
}

const { locale = 'en', currentPath = '/' } = Astro.props;
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL;

const navLinks: NavLink[] = [
  {
    label: locale === 'es' ? 'Servicios' : 'Services',
    href: localizeUrl('/services/', locale),
    current: currentPath.startsWith('/services') || currentPath.startsWith('/es/services'),
  },
  {
    label: locale === 'es' ? 'Solicitar' : 'Apply',
    href: localizeUrl('/apply/', locale),
    current: currentPath.startsWith('/apply') || currentPath.startsWith('/es/apply'),
  },
  {
    label: locale === 'es' ? 'Ayuda' : 'Help',
    href: localizeUrl('/help/', locale),
    current: currentPath === '/help/' || currentPath === '/es/help/',
  },
  {
    label: locale === 'es' ? 'Contacto' : 'Contact',
    href: localizeUrl('/contact/', locale),
    current: currentPath === '/contact/' || currentPath === '/es/contact/',
  },
];

// Language toggle
const altLocale = locale === 'en' ? 'es' : 'en';
const altLocaleLabel = locale === 'en' ? 'Español' : 'English';
const altLocalePath = locale === 'en'
  ? `/es${currentPath === '/' ? '/' : currentPath}`
  : currentPath.replace(/^\/es/, '') || '/';
---

<header class="usa-header usa-header--basic">
  <div class="usa-nav-container">
    <div class="usa-navbar">
      <div class="usa-logo">
        <em class="usa-logo__text">
          <a href={localizeUrl('/', locale)} title={t('site.name')} aria-label={t('site.name')}>
            {siteConfig.name}
          </a>
        </em>
      </div>
      <button
        type="button"
        class="usa-menu-btn"
        aria-label={t('nav.menu')}
      >
        {t('nav.menu')}
      </button>
    </div>

    <nav
      aria-label={t('nav.primary')}
      class="usa-nav"
    >
      <button type="button" class="usa-nav__close" aria-label={t('nav.close')}>
        <img src={`${base}uswds/img/usa-icons/close.svg`} role="img" alt="" />
      </button>

      <ul class="usa-nav__primary usa-accordion">
        {navLinks.map((link) => (
          <li class="usa-nav__primary-item">
            <a
              href={link.href}
              class:list={['usa-nav-link', { 'usa-current': link.current }]}
              aria-current={link.current ? 'page' : undefined}
            >
              <span>{link.label}</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="usa-nav__secondary">
        <ul class="usa-nav__secondary-links">
          <li class="usa-nav__secondary-item">
            <a href={altLocalePath} hreflang={altLocale} lang={altLocale}>
              {altLocaleLabel}
            </a>
          </li>
        </ul>
      </div>
    </nav>
  </div>
</header>
