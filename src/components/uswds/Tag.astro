---
/**
 * Tag — usa-tag
 * https://designsystem.digital.gov/components/tag/
 *
 * Small label for status, category, or metadata.
 */

interface Props {
  /** Background color token applied via usa-tag--{color} */
  color?: 'new' | 'informative' | 'cool' | 'warn' | 'error' | 'success';
  /** Larger font size */
  big?: boolean;
  class?: string;
}

const { color, big = false, class: className } = Astro.props;
---

<span
  class:list={[
    'usa-tag',
    color && `usa-tag--${color}`,
    big && 'usa-tag--big',
    className,
  ]}
>
  <slot />
</span>
