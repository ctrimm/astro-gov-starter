---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '../components/uswds/Breadcrumb.astro';
import Alert from '../components/uswds/Alert.astro';
import SummaryBox from '../components/uswds/SummaryBox.astro';
import type { Locale } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';

interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
  breadcrumbs?: BreadcrumbItem[];
  acceptingApplications?: boolean;
  applyHref?: string;
}

const {
  title,
  description,
  locale = 'en',
  breadcrumbs = [],
  acceptingApplications = true,
  applyHref,
} = Astro.props;

const t = useTranslations(locale);
const allCrumbs = [
  { label: locale === 'es' ? 'Inicio' : 'Home', href: locale === 'es' ? '/es/' : '/' },
  { label: locale === 'es' ? 'Servicios' : 'Services', href: locale === 'es' ? '/es/services/' : '/services/' },
  ...breadcrumbs,
];
---

<BaseLayout title={title} description={description} locale={locale}>
  <div class="grid-container usa-section">
    <Breadcrumb items={allCrumbs} wrap />
    <div class="grid-row grid-gap">
      <div class="grid-col-12 tablet:grid-col-8">
        {!acceptingApplications && (
          <Alert type="warning" slim>
            {locale === 'es'
              ? 'Este programa no está aceptando solicitudes nuevas en este momento.'
              : 'This program is not accepting new applications at this time.'}
          </Alert>
        )}

        <h1>{title}</h1>
        <div class="usa-prose">
          <slot />
        </div>
      </div>

      <div class="grid-col-12 tablet:grid-col-4">
        <slot name="sidebar" />

        {applyHref && acceptingApplications && (
          <SummaryBox
            heading={locale === 'es' ? 'Solicitar ahora' : 'Ready to apply?'}
            label={locale === 'es' ? 'Solicitar ahora' : 'Apply now'}
            class="margin-top-4"
          >
            <p>
              {locale === 'es'
                ? 'La solicitud en línea tarda aproximadamente 20 minutos.'
                : 'The online application takes about 20 minutes.'}
            </p>
            <a href={applyHref} class="usa-button usa-button--big">
              {t('home.applyNow')}
            </a>
          </SummaryBox>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
