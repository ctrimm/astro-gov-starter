---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/uswds/Breadcrumb.astro';
import { siteConfig } from '../config/site';

const locale = 'en';
const updatedDate = new Date('2025-01-01');
---

<BaseLayout
  title="Accessibility statement"
  description="Our commitment to digital accessibility and how to request an accommodation."
  locale={locale}
>
  <div class="grid-container usa-section">
    <div class="grid-row">
      <div class="grid-col-12 tablet:grid-col-8">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Accessibility statement', href: '/accessibility/' },
        ]} />

        <h1>Accessibility statement</h1>

        <p>
          <em>Last updated: {updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</em>
        </p>

        <div class="usa-prose">
          <h2>Our commitment</h2>
          <p>
            {siteConfig.name} is committed to making its website accessible to all people,
            including those with disabilities. We strive to conform to the
            <a href="https://www.w3.org/TR/WCAG21/" rel="noreferrer" class="usa-link">
              Web Content Accessibility Guidelines (WCAG) 2.1, Level AA
            </a>{' '}
            and Section 508 of the Rehabilitation Act.
          </p>

          <h2>Standards</h2>
          <p>This website is designed to be:</p>
          <ul>
            <li>Perceivable — information is presentable in ways users can perceive</li>
            <li>Operable — interface components and navigation can be operated by all users</li>
            <li>Understandable — information and operations are understandable</li>
            <li>Robust — content can be interpreted by a wide variety of technologies including assistive technologies</li>
          </ul>

          <h2>Known limitations</h2>
          <p>
            We are continuously working to improve the accessibility of our website.
            Some older content may not fully meet all accessibility standards.
            We are working to remediate known issues.
          </p>
          <p>
            <!-- TODO: Update with actual known issues before launch -->
            No known accessibility barriers have been identified at this time.
          </p>

          <h2>How to request an accommodation</h2>
          <p>
            If you experience any difficulty accessing our website, or if you need
            information in an alternative format (such as large print, Braille, or audio),
            please contact us:
          </p>
          <ul>
            <li>
              <strong>Phone:</strong>{' '}
              <a href="tel:18005550100" class="usa-link">1&#8209;800&#8209;555&#8209;0100</a>
              (TTY: <a href="tel:18005550101" class="usa-link">1&#8209;800&#8209;555&#8209;0101</a>)
            </li>
            <li>
              <strong>Online:</strong>{' '}
              <a href="/contact/" class="usa-link">Use our contact form</a>
            </li>
          </ul>
          <p>We will respond within 2 business days.</p>

          <h2>Third-party content</h2>
          <p>
            Some pages on this website may link to or embed content from third-party websites.
            We cannot control the accessibility of content on those sites. If you encounter
            an accessibility barrier on a linked site, contact that organization directly.
          </p>

          <h2>Feedback</h2>
          <p>
            We welcome feedback on the accessibility of this website.
            Please let us know if you encounter accessibility barriers by{' '}
            <a href="/contact/" class="usa-link">contacting us</a>.
          </p>

          <h2>Formal complaints</h2>
          <p>
            If you are not satisfied with our response to an accessibility complaint,
            you may contact the{' '}
            <a href="https://www.hhs.gov/civil-rights/for-individuals/disability/index.html" rel="noreferrer" class="usa-link">
              U.S. Department of Health and Human Services
            </a>{' '}
            or the{' '}
            <a href="https://www.section508.gov/" rel="noreferrer" class="usa-link">
              Section508.gov
            </a>{' '}
            program office.
          </p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
