---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SummaryBox from '../../components/uswds/SummaryBox.astro';

const locale = 'es';
---

<BaseLayout
  title="Contáctenos"
  description="Comuníquese con nuestra oficina por teléfono, correo electrónico o en persona."
  locale={locale}
>
  <div class="grid-container usa-section">
    <h1>Contáctenos</h1>
    <p class="usa-intro">
      Estamos aquí para ayudar. Comuníquese con nosotros por teléfono, formulario en línea
      o visítenos en persona.
    </p>

    <div class="grid-row grid-gap">
      <div class="grid-col-12 tablet:grid-col-7">
        <h2>Enviar un mensaje</h2>
        <form
          class="usa-form usa-form--large"
          method="post"
          action="#"
          aria-label="Formulario de contacto"
          novalidate
          lang="es"
        >
          <p class="usa-hint">Los campos requeridos están marcados con un asterisco (*).</p>

          <div class="usa-form-group">
            <label class="usa-label" for="contact-name-es">
              Nombre completo <abbr title="requerido" aria-label="requerido">*</abbr>
            </label>
            <input class="usa-input" id="contact-name-es" name="name" type="text" autocomplete="name" required aria-required="true" />
          </div>

          <div class="usa-form-group">
            <label class="usa-label" for="contact-email-es">
              Correo electrónico <abbr title="requerido" aria-label="requerido">*</abbr>
            </label>
            <input class="usa-input" id="contact-email-es" name="email" type="email" autocomplete="email" required aria-required="true" />
          </div>

          <fieldset class="usa-fieldset">
            <legend class="usa-legend">
              ¿Su pregunta es sobre? <abbr title="requerido" aria-label="requerido">*</abbr>
            </legend>
            {['Beneficios SNAP', 'Medicaid', 'WIC', 'Asistencia para cuidado infantil', 'Estado de mi solicitud', 'Otro'].map((topic) => (
              <div class="usa-radio">
                <input
                  class="usa-radio__input"
                  id={`topic-es-${topic.replace(/\s+/g, '-').toLowerCase()}`}
                  type="radio"
                  name="topic"
                  value={topic}
                />
                <label class="usa-radio__label" for={`topic-es-${topic.replace(/\s+/g, '-').toLowerCase()}`}>
                  {topic}
                </label>
              </div>
            ))}
          </fieldset>

          <div class="usa-form-group">
            <label class="usa-label" for="contact-message-es">
              Mensaje <abbr title="requerido" aria-label="requerido">*</abbr>
            </label>
            <span class="usa-hint" id="contact-message-hint-es">
              No incluya su número de Seguro Social ni número de caso en su mensaje.
            </span>
            <textarea class="usa-textarea" id="contact-message-es" name="message" rows={6} required aria-required="true" aria-describedby="contact-message-hint-es"></textarea>
          </div>

          <button type="submit" class="usa-button usa-button--big">Enviar mensaje</button>
        </form>
      </div>

      <div class="grid-col-12 tablet:grid-col-5">
        <SummaryBox heading="Otras formas de contactarnos" label="Otras formas de contactarnos">
          <h3 class="font-heading-sm margin-bottom-0">Teléfono</h3>
          <p>
            <a href="tel:18005550100" class="usa-link">1-800-555-0100</a><br />
            TTY: <a href="tel:18005550101" class="usa-link">1-800-555-0101</a><br />
            <span class="text-base font-sans-sm">Lunes a viernes, 8 a.m.–8 p.m. ET</span>
          </p>
          <h3 class="font-heading-sm margin-bottom-0">Tiempo de respuesta</h3>
          <p>Respondemos a los mensajes en 2 días hábiles.</p>
        </SummaryBox>
      </div>
    </div>
  </div>
</BaseLayout>
