---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/uswds/Hero.astro';
import ServiceCard from '../../components/uswds/ServiceCard.astro';
import ProcessList from '../../components/uswds/ProcessList.astro';
import ProcessListItem from '../../components/uswds/ProcessListItem.astro';
import CallToAction from '../../components/uswds/CallToAction.astro';
import SiteAlert from '../../components/uswds/SiteAlert.astro';
import { siteConfig } from '../../config/site';
import { useTranslations } from '../../i18n/utils';
import { idToSlug } from '../../utils/content';

const locale = 'es';
const t = useTranslations(locale);

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const now = new Date();
const activeAnnouncements = await getCollection('announcements', ({ data }) => {
  if (data.draft || !data.showInEs) return false;
  if (data.endDate && data.endDate < now) return false;
  return data.startDate <= now;
});
---

<BaseLayout title={t('site.name')} description={siteConfig.description} locale={locale}>
  {activeAnnouncements.map((ann) => (
    <SiteAlert
      type={ann.data.severity === 'warning' ? 'emergency' : 'info'}
      heading={ann.data.title}
    >
      {ann.data.linkText && ann.data.linkUrl && (
        <a href={ann.data.linkUrl} class="usa-link">{ann.data.linkText}</a>
      )}
    </SiteAlert>
  ))}

  <Hero
    heading={t('home.heroHeading')}
    headingSuffix={t('home.heroHeadingAlt')}
    subheading={t('home.heroSubheading')}
    ctaText={t('home.heroCta')}
    ctaHref="/es/services/"
    label="Introducción"
  />

  <section class="usa-section" aria-labelledby="services-heading-es">
    <div class="grid-container">
      <h2 id="services-heading-es" class="font-heading-xl">{t('home.servicesHeading')}</h2>
      <p class="usa-intro">{t('home.servicesSubheading')}</p>

      <ul class="usa-card-group">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            summary={service.data.summary}
            href={`/es/services/${idToSlug(service.id)}/`}
            ctaText={t('home.learnMore')}
            acceptingApplications={service.data.acceptingApplications}
            class="tablet:grid-col-4"
          />
        ))}
      </ul>

      <p class="margin-top-4">
        <a href="/es/services/" class="usa-link">Ver todos los programas →</a>
      </p>
    </div>
  </section>

  <CallToAction
    heading="Cómo solicitar"
    bg="base-lightest"
    textColor="ink"
    primaryCta={{ label: t('home.applyNow'), href: '/es/services/' }}
  >
    <ProcessList>
      <ProcessListItem heading="Verifique su elegibilidad">
        <p>Responda algunas preguntas para saber qué programas puede calificar. Esto toma alrededor de 5 minutos y no inicia una solicitud.</p>
      </ProcessListItem>
      <ProcessListItem heading="Reúna sus documentos">
        <p>Es posible que necesite comprobante de identidad, ingresos y residencia. Nuestra lista le dirá exactamente qué traer.</p>
      </ProcessListItem>
      <ProcessListItem heading="Envíe su solicitud">
        <p>Solicite en línea en aproximadamente 20 minutos. Recibirá un número de confirmación de inmediato y una decisión en 30 días.</p>
      </ProcessListItem>
    </ProcessList>
  </CallToAction>
</BaseLayout>
