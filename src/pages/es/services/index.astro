---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/uswds/Hero.astro';
import ServiceCard from '../../../components/uswds/ServiceCard.astro';
import { idToSlug } from '../../../utils/content';

const locale = 'es';
const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Programas y servicios" description="Encuentre los programas para los que puede ser elegible." locale={locale}>
  <Hero
    heading="Programas y servicios"
    subheading="Ofrecemos programas de asistencia para residentes elegibles. Seleccione un programa para obtener más información e iniciar su solicitud."
    label="Servicios"
    small
  />

  <div class="grid-container usa-section">
    <p class="text-base font-sans-sm">Mostrando {services.length} programas</p>

    <ul class="usa-card-group">
      {services.map((service) => (
        <ServiceCard
          title={service.data.title}
          summary={service.data.summary}
          href={`/es/services/${idToSlug(service.id)}/`}
          ctaText="Más información"
          acceptingApplications={service.data.acceptingApplications}
          class="tablet:grid-col-6 desktop:grid-col-4"
        />
      ))}
    </ul>

    <div class="usa-prose margin-top-6">
      <p>
        <strong>¿No encuentra lo que necesita?</strong> Visite nuestro{' '}
        <a href="/es/help/" class="usa-link">centro de ayuda</a> o{' '}
        <a href="/es/contact/" class="usa-link">contáctenos</a>.
      </p>
    </div>
  </div>
</BaseLayout>
