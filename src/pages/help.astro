---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/uswds/Search.astro';
import Accordion from '../components/uswds/Accordion.astro';
import AccordionItem from '../components/uswds/AccordionItem.astro';
import SummaryBox from '../components/uswds/SummaryBox.astro';
import SideNav from '../components/uswds/SideNav.astro';

const locale = 'en';
const faqs = (await getCollection('faqs', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const generalFaqs = faqs.filter((f) => f.data.tags.includes('general'));
const snapFaqs = faqs.filter((f) => f.data.tags.includes('snap') && !f.data.tags.includes('general'));
const otherFaqs = faqs.filter((f) => !f.data.tags.includes('general') && !f.data.tags.includes('snap'));
---

<BaseLayout
  title="Help center"
  description="Find answers to common questions about our programs and services."
  locale={locale}
>
  <div class="grid-container usa-section">
    <h1>Help center</h1>
    <p class="usa-intro">
      Find answers to common questions. If you don't find what you need,{' '}
      <a href="/contact/" class="usa-link">contact us</a> and we'll help.
    </p>

    <Search label="Search help topics" action="/search" class="margin-bottom-4" />

    <div class="grid-row grid-gap">
      <div class="grid-col-12 tablet:grid-col-8">
        {generalFaqs.length > 0 && (
          <section aria-labelledby="general-faqs-heading">
            <h2 id="general-faqs-heading">General questions</h2>
            <Accordion multiselectable>
              {generalFaqs.map(async (faq, i) => {
                const { Content } = await render(faq);
                return (
                  <AccordionItem heading={faq.data.question} expanded={i === 0} headingLevel="h3">
                    <Content />
                  </AccordionItem>
                );
              })}
            </Accordion>
          </section>
        )}

        {snapFaqs.length > 0 && (
          <section aria-labelledby="snap-faqs-heading" class="margin-top-5">
            <h2 id="snap-faqs-heading">SNAP questions</h2>
            <Accordion multiselectable>
              {snapFaqs.map(async (faq) => {
                const { Content } = await render(faq);
                return (
                  <AccordionItem heading={faq.data.question} headingLevel="h3">
                    <Content />
                  </AccordionItem>
                );
              })}
            </Accordion>
          </section>
        )}

        {otherFaqs.length > 0 && (
          <section class="margin-top-5" aria-labelledby="all-faqs-heading">
            <h2 id="all-faqs-heading">More questions</h2>
            <Accordion multiselectable>
              {otherFaqs.map(async (faq) => {
                const { Content } = await render(faq);
                return (
                  <AccordionItem heading={faq.data.question} headingLevel="h3">
                    <Content />
                  </AccordionItem>
                );
              })}
            </Accordion>
          </section>
        )}
      </div>

      <div class="grid-col-12 tablet:grid-col-4">
        <SideNav
          label="Help topics"
          items={[
            { label: 'General questions', href: '#general-faqs-heading' },
            { label: 'SNAP questions', href: '#snap-faqs-heading' },
            { label: 'Contact us', href: '/contact/' },
          ]}
        />

        <SummaryBox heading="Still need help?" class="margin-top-4">
          <p>Call us at <a href="tel:18005550100" class="usa-link">1-800-555-0100</a></p>
          <p class="font-sans-sm text-base">Monday–Friday, 8 a.m.–8 p.m. ET</p>
          <a href="/contact/" class="usa-button usa-button--outline">Send a message</a>
        </SummaryBox>
      </div>
    </div>
  </div>
</BaseLayout>
