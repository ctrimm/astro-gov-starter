---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../config/site';
import { useTranslations } from '../i18n/utils';
import { idToSlug } from '../utils/content';

const locale = 'en';
const t = useTranslations(locale);

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const now = new Date();
const activeAnnouncements = (await getCollection('announcements', ({ data }) => {
  if (data.draft) return false;
  if (data.endDate && data.endDate < now) return false;
  return data.startDate <= now;
}));
---

<BaseLayout
  title={siteConfig.name}
  description={siteConfig.description}
  locale={locale}
>
  {activeAnnouncements.map((ann) => (
    <div
      class:list={[
        'usa-site-alert',
        ann.data.severity === 'warning' && 'usa-site-alert--emergency',
        ann.data.severity === 'info' && 'usa-site-alert--info',
      ]}
      role="alert"
    >
      <div class="usa-alert">
        <div class="usa-alert__body">
          <h2 class="usa-alert__heading">{ann.data.title}</h2>
          {ann.data.linkText && ann.data.linkUrl && (
            <p class="usa-alert__text">
              <a href={ann.data.linkUrl} class="usa-link">{ann.data.linkText}</a>
            </p>
          )}
        </div>
      </div>
    </div>
  ))}

  <section class="usa-hero" aria-label="Introduction">
    <div class="grid-container">
      <div class="usa-hero__callout">
        <h1 class="usa-hero__heading">
          <span class="usa-hero__heading--alt">{t('home.heroHeading')}</span>
          {t('home.heroHeadingAlt')}
        </h1>
        <p>{t('home.heroSubheading')}</p>
        <a class="usa-button usa-button--big" href="/services/">
          {t('home.heroCta')}
        </a>
      </div>
    </div>
  </section>

  <section class="usa-section" aria-labelledby="services-heading">
    <div class="grid-container">
      <h2 id="services-heading" class="font-heading-xl">{t('home.servicesHeading')}</h2>
      <p class="usa-intro">{t('home.servicesSubheading')}</p>

      <ul class="usa-card-group">
        {services.map((service) => {
          const slug = idToSlug(service.id);
          return (
            <li class="usa-card tablet:grid-col-4">
              <div class="usa-card__container">
                <div class="usa-card__header">
                  <h3 class="usa-card__heading">{service.data.title}</h3>
                </div>
                <div class="usa-card__body">
                  <p>{service.data.summary}</p>
                </div>
                <div class="usa-card__footer">
                  <a href={`/services/${slug}/`} class="usa-button">
                    {t('home.learnMore')}
                  </a>
                </div>
              </div>
            </li>
          );
        })}
      </ul>

      <p class="margin-top-4">
        <a href="/services/" class="usa-link">View all programs →</a>
      </p>
    </div>
  </section>

  <section class="usa-section bg-primary-darker" aria-labelledby="process-heading">
    <div class="grid-container">
      <h2 id="process-heading" class="font-heading-xl text-white">How to apply</h2>
      <ol class="usa-process-list">
        <li class="usa-process-list__item">
          <h3 class="usa-process-list__heading">Check eligibility</h3>
          <p>Answer a few questions to find out which programs you may qualify for. This takes about 5 minutes and does not start an application.</p>
        </li>
        <li class="usa-process-list__item">
          <h3 class="usa-process-list__heading">Gather documents</h3>
          <p>You may need proof of identity, income, and residency. Our checklist will tell you exactly what to bring.</p>
        </li>
        <li class="usa-process-list__item">
          <h3 class="usa-process-list__heading">Submit your application</h3>
          <p>Apply online in about 20 minutes. You'll get a confirmation number immediately and a decision within 30 days.</p>
        </li>
      </ol>
      <a href="/services/" class="usa-button usa-button--outline usa-button--inverse">
        {t('home.applyNow')}
      </a>
    </div>
  </section>
</BaseLayout>
