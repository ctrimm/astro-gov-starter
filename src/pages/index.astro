---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/uswds/Hero.astro';
import ServiceCard from '../components/uswds/ServiceCard.astro';
import ProcessList from '../components/uswds/ProcessList.astro';
import ProcessListItem from '../components/uswds/ProcessListItem.astro';
import CallToAction from '../components/uswds/CallToAction.astro';
import SiteAlert from '../components/uswds/SiteAlert.astro';
import { siteConfig } from '../config/site';
import { useTranslations } from '../i18n/utils';
import { idToSlug } from '../utils/content';

const locale = 'en';
const t = useTranslations(locale);

const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

const now = new Date();
const activeAnnouncements = await getCollection('announcements', ({ data }) => {
  if (data.draft) return false;
  if (data.endDate && data.endDate < now) return false;
  return data.startDate <= now;
});
---

<BaseLayout title={siteConfig.name} description={siteConfig.description} locale={locale}>
  {activeAnnouncements.map((ann) => (
    <SiteAlert
      type={ann.data.severity === 'warning' ? 'emergency' : 'info'}
      heading={ann.data.title}
    >
      {ann.data.linkText && ann.data.linkUrl && (
        <a href={ann.data.linkUrl} class="usa-link">{ann.data.linkText}</a>
      )}
    </SiteAlert>
  ))}

  <Hero
    heading={t('home.heroHeading')}
    headingSuffix={t('home.heroHeadingAlt')}
    subheading={t('home.heroSubheading')}
    ctaText={t('home.heroCta')}
    ctaHref="/services/"
  />

  <section class="usa-section" aria-labelledby="services-heading">
    <div class="grid-container">
      <h2 id="services-heading" class="font-heading-xl">{t('home.servicesHeading')}</h2>
      <p class="usa-intro">{t('home.servicesSubheading')}</p>

      <ul class="usa-card-group">
        {services.map((service) => (
          <ServiceCard
            title={service.data.title}
            summary={service.data.summary}
            href={`/services/${idToSlug(service.id)}/`}
            ctaText={t('home.learnMore')}
            acceptingApplications={service.data.acceptingApplications}
            class="tablet:grid-col-4"
          />
        ))}
      </ul>

      <p class="margin-top-4">
        <a href="/services/" class="usa-link">View all programs →</a>
      </p>
    </div>
  </section>

  <CallToAction
    heading="How to apply"
    primaryCta={{ label: t('home.applyNow'), href: '/services/' }}
  >
    <ProcessList>
      <ProcessListItem heading="Check eligibility">
        <p>Answer a few questions to find out which programs you may qualify for. This takes about 5 minutes and does not start an application.</p>
      </ProcessListItem>
      <ProcessListItem heading="Gather documents">
        <p>You may need proof of identity, income, and residency. Our checklist will tell you exactly what to bring.</p>
      </ProcessListItem>
      <ProcessListItem heading="Submit your application">
        <p>Apply online in about 20 minutes. You'll get a confirmation number immediately and a decision within 30 days.</p>
      </ProcessListItem>
    </ProcessList>
  </CallToAction>
</BaseLayout>
