---
import { getCollection, render } from 'astro:content';
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import SummaryBox from '../../components/uswds/SummaryBox.astro';
import { idToSlug } from '../../utils/content';

export async function getStaticPaths() {
  const services = await getCollection('services', ({ data }) => !data.draft);
  return services.map((service) => ({
    params: { slug: idToSlug(service.id) },
    props: { service },
  }));
}

const { service } = Astro.props;
const { Content } = await render(service);
const slug = idToSlug(service.id);
const locale = 'en';
const applyHref = service.data.applySlug ? `/apply/${service.data.applySlug}/` : undefined;
---

<ServiceLayout
  title={service.data.title}
  description={service.data.description}
  locale={locale}
  breadcrumbs={[{ label: service.data.title, href: `/services/${slug}/` }]}
  acceptingApplications={service.data.acceptingApplications}
  applyHref={applyHref}
>
  <Content />

  <Fragment slot="sidebar">
    {service.data.eligibility.length > 0 && (
      <SummaryBox heading="Eligibility at a glance" label="Eligibility at a glance">
        <dl>
          {service.data.eligibility.map((item) => (
            <>
              <dt class="text-bold">{item.label}</dt>
              <dd class="margin-left-0 margin-bottom-1">{item.value}</dd>
            </>
          ))}
        </dl>
      </SummaryBox>
    )}

    {service.data.keyFacts.length > 0 && (
      <SummaryBox heading="Key facts" class="margin-top-3">
        <dl>
          {service.data.keyFacts.map((fact) => (
            <>
              <dt class="text-bold">{fact.label}</dt>
              <dd class="margin-left-0 margin-bottom-1">{fact.value}</dd>
            </>
          ))}
        </dl>
      </SummaryBox>
    )}

    {service.data.related.length > 0 && (
      <div class="margin-top-3">
        <h2 class="font-heading-md">Related programs</h2>
        <ul class="usa-list">
          {service.data.related.map((relSlug) => (
            <li>
              <a href={`/services/${relSlug}/`} class="usa-link">{relSlug.toUpperCase()}</a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </Fragment>
</ServiceLayout>
