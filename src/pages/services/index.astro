---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/uswds/Hero.astro';
import ServiceCard from '../../components/uswds/ServiceCard.astro';
import { idToSlug } from '../../utils/content';

const locale = 'en';
const services = (await getCollection('services', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Services" description="Find programs and services you may be eligible for." locale={locale}>
  <Hero
    heading="Programs &amp; services"
    subheading="We offer assistance programs for eligible residents. Select a program to learn more and start your application."
    label="Services"
    small
  />

  <div class="grid-container usa-section">
    <p class="text-base font-sans-sm">Showing {services.length} programs</p>

    <ul class="usa-card-group">
      {services.map((service) => (
        <ServiceCard
          title={service.data.title}
          summary={service.data.summary}
          href={`/services/${idToSlug(service.id)}/`}
          ctaText="Learn more"
          acceptingApplications={service.data.acceptingApplications}
          class="tablet:grid-col-6 desktop:grid-col-4"
        />
      ))}
    </ul>

    <div class="usa-prose margin-top-6">
      <p>
        <strong>Don't see what you need?</strong> Visit our{' '}
        <a href="/help/" class="usa-link">help center</a> or{' '}
        <a href="/contact/" class="usa-link">contact us</a>.
      </p>
      <p>
        You can also visit{' '}
        <a href="https://www.benefits.gov/" class="usa-link" rel="noreferrer">Benefits.gov</a>{' '}
        to find additional federal programs.
      </p>
    </div>
  </div>
</BaseLayout>
